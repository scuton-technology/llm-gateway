# LLM Gateway Configuration
# Copy this file to config.yaml and fill in your API keys.

server:
  port: 8080
  db_path: gateway.db

# Cloud Providers (Tier 1)
# Set API keys as environment variables or fill in below.
providers:
  anthropic:
    api_key: ${ANTHROPIC_API_KEY}
  openai:
    api_key: ${OPENAI_API_KEY}
  google:
    api_key: ${GOOGLE_API_KEY}
  groq:
    api_key: ${GROQ_API_KEY}
  mistral:
    api_key: ${MISTRAL_API_KEY}
  cohere:
    api_key: ${COHERE_API_KEY}
  xai:
    api_key: ${XAI_API_KEY}
  perplexity:
    api_key: ${PERPLEXITY_API_KEY}
  together:
    api_key: ${TOGETHER_API_KEY}

# Local/Self-hosted Providers (Tier 2)
# Set OLLAMA_ENABLED=true etc. to activate.
local:
  ollama:
    enabled: false
    base_url: http://localhost:11434
  lmstudio:
    enabled: false
    base_url: http://localhost:1234
  vllm:
    enabled: false
    base_url: http://localhost:8000
