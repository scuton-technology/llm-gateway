# LLM Gateway — Environment Variables
# Copy to .env and fill in your API keys.

PORT=8080
DB_PATH=gateway.db
PUBLIC_RATE_LIMIT_RPM=60

# Security
# Set this explicitly in production so encrypted provider secrets remain portable across restarts/hosts.
LLM_GATEWAY_ENCRYPTION_KEY=
# Only enable if the gateway sits behind a trusted reverse proxy that sets X-Forwarded-* headers.
LLM_GATEWAY_TRUST_PROXY_HEADERS=false

# Cloud Providers (Tier 1)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=
COHERE_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
TOGETHER_API_KEY=

# Local Providers (Tier 2) — set to "true" to enable
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_ENABLED=false
LMSTUDIO_BASE_URL=http://localhost:1234
VLLM_ENABLED=false
VLLM_BASE_URL=http://localhost:8000
